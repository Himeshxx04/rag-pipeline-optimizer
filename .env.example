# ─────────────────────────────────────────
# RAG Pipeline Optimizer — Environment Config
# Copy this file to .env and fill in your values
# Never commit .env to version control
# ─────────────────────────────────────────

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini              # Model used for generation pipelines
JUDGE_MODEL=gpt-4o                    # Model used for answer evaluation (judge)

# Optimizer weights (must sum to 1.0)
QUALITY_WEIGHT=0.6
COST_WEIGHT=0.2
LATENCY_WEIGHT=0.2

# Guardrails
SIMILARITY_THRESHOLD=0.75             # Minimum cosine similarity for retrieval
TOKEN_BUDGET=2000                     # Max tokens per generation request
MIN_GROUNDEDNESS_SCORE=0.6            # Auto-reject answers below this judge score

# FAISS
FAISS_INDEX_PATH=./faiss_index        # Local path to persist the FAISS index
TOP_K_CHUNKS=5                        # Number of chunks retrieved per query

# Database (SQLAlchemy)
DATABASE_URL=sqlite:///./rag_metrics.db   # Use postgresql://user:pass@host/db for prod

# LangSmith tracing (optional — remove if not using)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your-langsmith-api-key
LANGCHAIN_PROJECT=rag-pipeline-optimizer

# Server
HOST=0.0.0.0
PORT=8000
